{
  "name": "layox",
  "private": true,
  "version": "0.0.0",
  "description": "Local-first photo album editor.",
  "author": "Layox Team",
  "main": "electron/main/index.mjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:electron:renderer": "tsc -b && vite build --mode electron",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "electron:start": "electron ./electron/main/index.mjs",
    "electron:dev:renderer": "vite --host",
    "electron:dev:desktop": "cross-env LAYOX_DEV_SERVER_URL=http://localhost:5173 electron ./electron/main/index.mjs",
    "electron:build:appimage": "npm run build:electron:renderer && electron-builder --config electron-builder.yml --linux AppImage --publish never"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "file-saver": "^2.0.5",
    "jspdf": "^4.2.0",
    "jszip": "^3.10.1",
    "konva": "^10.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-konva": "^19.2.3",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "electron": "^36.3.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
